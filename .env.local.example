# App URL (used in email templates — set to your deployed domain)
NEXT_PUBLIC_APP_URL=https://app.samvayamatrimony.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase CLI (used by supabase link / db push / gen types)
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Resend (Email)
RESEND_API_KEY=your-resend-api-key

# WhatsApp Support Number (with country code, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=919742811599

# Team notification email (receives form submission alerts)
TEAM_NOTIFICATION_EMAIL=team@samvayamatrimony.com

# Airtable sync (optional — needed only if Airtable sync is enabled)
AIRTABLE_API_KEY=your-airtable-personal-access-token
AIRTABLE_BASE_ID=your-airtable-base-id
AIRTABLE_WEBHOOK_SECRET=your-airtable-webhook-secret

# Cron job authentication (generate with: openssl rand -hex 32)
CRON_SECRET=your-cron-secret

# Web Push (VAPID) keys (generate at https://vapidkeys.com or via web-push CLI)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Waitlist (external Supabase project — "Samvaya Waitlist")
# Set USE_LIVE_WAITLIST=true when you want the admin dashboard to show the real waitlist count.
# Leave it false to keep using demo data in Phase 2's own waitlist table.
WAITLIST_SUPABASE_URL=your-waitlist-supabase-url
WAITLIST_SUPABASE_SERVICE_ROLE_KEY=your-waitlist-supabase-service-role-key
USE_LIVE_WAITLIST=false

# Vercel (auto-generated by vercel link)
VERCEL_OIDC_TOKEN=auto-generated-by-vercel-cli
